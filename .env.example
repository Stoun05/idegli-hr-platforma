# Public Supabase project configuration used by the Vite frontend.
# Never put a service_role key in a VITE_* variable or in GitHub Pages.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: copy successful Supabase submissions into this browser's localStorage
# so they also appear in the current demo admin panel. Keep false in production.
VITE_ENABLE_LOCAL_ADMIN_MIRROR=false
